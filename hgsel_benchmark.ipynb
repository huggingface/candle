      "cell_type": "markdown",
      "source": [
        "## ══════════════════════════════════════════════════════════════\n",
        "## HGSEL: Hash-based Sparse Expert Layer (PyTorch)\n",
        "## ══════════════════════════════════════════════════════════════\n",
        "\n",
        "This mirrors the Rust implementation in `candle-zach/candle-nn/src/hgsel/`."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ─── Multi-Hash Router ───────────────────────────────────────\n",
        "\n",
        "import hashlib\n",
        "\n",
        "def sip_hash(data: bytes, seed0: int, seed1: int) -> int:\n",
        "    \"\"\"SipHash-2-4 — fast, good distribution, non-cryptographic\"\"\"\n",
        "    v0 = 0x736f6d6570736575 ^ seed0\n",
        "    v1 = 0x646f72616e646f6d ^ seed1\n",
        "    v2 = 0x6c7967656e657261 ^ seed0\n",
        "    v3 = 0x7465646279746553 ^ seed1\n",
        "    \n",
        "    # Process 8-byte chunks\n",
        "    for i in range(0, len(data), 8):\n",
        "        chunk = data[i:i+8]\n",
        "        # Pad if needed\n",
        "        if len(chunk) < 8:\n",
        "            chunk = chunk + b'\\x00' * (8 - len(chunk))\n",
        "        \n",
        "        msg = int.from_bytes(chunk, 'little')\n",
        "        v0 ^= msg\n",
        "        v0 = (v0 * 0x9e3779b97f4a7c15) & 0xFFFFFFFFFFFFFFFF\n",
        "        v1 ^= v0\n",
        "        v1 = (v1 ^ (v0 << 13)) & 0xFFFFFFFFFFFFFFFF\n",
        "        v1 = (v1 * 0x85ebca6b) & 0xFFFFFFFFFFFFFFFF\n",
        "        v2 ^= v1\n",
        "        v2 = (v2 ^ (v1 << 17)) & 0xFFFFFFFFFFFFFFFF\n",
        "        v2 = (v2 * 0xc2b2ae35) & 0xFFFFFFFFFFFFFFFF\n",
        "        v3 ^= v2\n",
        "        v3 = (v3 ^ (v2 << 21)) & 0xFFFFFFFFFFFFFFFF\n",
        "        v3 = (v3 * 0x9e3779b97f4a7c15) & 0xFFFFFFFFFFFFFFFF\n",
        "    \n",
        "    v0 ^= 0xFF\n",
        "    v0 = (v0 * 0x9e3779b97f4a7c15) & 0xFFFFFFFFFFFFFFFF\n",
        "    v1 ^= v0\n",
        "    v1 = (v1 * 0x85ebca6b) & 0xFFFFFFFFFFFFFFFF\n",
        "    v2 ^= v1\n",
        "    v2 = (v2 * 0xc2b2ae35) & 0xFFFFFFFFFFFFFFFF\n",
        "    v3 ^= v2\n",
        "    v3 = (v3 * 0x9e3779b97f4a7c15) & 0xFFFFFFFFFFFFFFFF\n",
        "    \n",
        "    return (v0 ^ v1 ^ v2 ^ v3) & 0xFFFFFFFFFFFFFFFF\n",
        "\n",
        "class MultiHashRouter(nn.Module):\n",
        "    \"\"\"\n",
        "    Deterministic sparse routing via multi-hash.\n",
        "    \n",
        "    salt > 0: more uniform (exploratory)\n",
        "    salt < 0: more concentrated (specialist)\n",
        "    \"\"\"\n",
        "    \n",
        "    def __init__(self, n_experts: int, k_active: int, n_hashes: int, d_model: int, layer_id: int = 0):\n",
        "        super().__init__()\n",
        "        self.n_experts = n_experts\n",
        "        self.k_active = k_active\n",
        "        self.n_hashes = n_hashes\n",
        "        self.layer_id = layer_id\n",
        "        self.salt = nn.Parameter(torch.zeros(1))\n",
        "    \n",
        "    def set_salt(self, salt: float):\n",
        "        self.salt.data.fill_(salt)\n",
        "    \n",
        "    def _hash_seed(self, hash_idx: int, expert_id: int) -> tuple:\n",
        "        base = (self.layer_id * 0x9e3779b97f4a7c15 + hash_idx + expert_id) & 0xFFFFFFFFFFFFFFFF\n",
        "        return (base, base * 0xbf3e0b9d6e3c8a2f & 0xFFFFFFFFFFFFFFFF)\n",
        "    \n",
        "    def forward(self, x: torch.Tensor) -> tuple:\n",
        "        \"\"\"\n",
        "        Args:\n",
        "            x: [batch, seq, d_model] or [batch*seq, d_model]\n",
        "        Returns:\n",
        "            expert_ids: [batch*seq, k_active] — selected expert indices\n",
        "            expert_weights: [batch*seq, k_active] — combination weights\n",
        "        \"\"\"\n",
        "        if x.dim() == 3:\n",
        "            batch, seq, d_model = x.shape\n",
        "            x = x.reshape(batch * seq, d_model)\n",
        "        else:\n",
        "            batch = x.shape[0]\n",
        "        \n",
        "        # Token bytes for hashing\n",
        "        x_bytes = x.cpu().numpy().tobytes()\n",
        "        \n",
        "        expert_ids = []\n",
        "        expert_weights = []\n",
        "        \n",
        "        for b in range(batch):\n",
        "            offset = b * x.shape[1] * 4  # 4 bytes per f32\n",
        "            token_bytes = x_bytes[offset:offset + x.shape[1] * 4]\n",
        "            \n",
        "            # Score each expert with multi-hash\n",
        "            scores = []\n",
        "            for e in range(self.n_experts):\n",
        "                score = 0.0\n",
        "                for h in range(self.n_hashes):\n",
        "                    seed0, seed1 = self._hash_seed(h, e)\n",
        "                    h_val = sip_hash(token_bytes, seed0, seed1)\n",
        "                    score += h_val / (2**64)\n",
        "                score /= self.n_hashes\n",
        "                scores.append(score)\n",
        "            \n",
        "            # Apply salt\n",
        "            salt_val = self.salt.item()\n",
        "            if abs(salt_val) > 1e-6:\n",
        "                shift = salt_val * 0.1\n",
        "                scores = [max(0.0, min(1.0, s + shift)) for s in scores]\n",
        "            \n",
        "            # Top-k selection\n",
        "            topk_idx = sorted(range(len(scores)), key=lambda i: scores[i], reverse=True)[:self.k_active]\n",
        "            topk_scores = [scores[i] for i in topk_idx]\n",
        "            \n",
        "            expert_ids.extend(topk_idx)\n",
        "            expert_weights.extend(topk_scores)\n",
        "        \n",
        "        expert_ids = torch.tensor(expert_ids, dtype=torch.long, device=device).reshape(batch, self.k_active)\n",
        "        expert_weights = torch.tensor(expert_weights, dtype=torch.float32, device=device).reshape(batch, self.k_active)\n",
        "        \n",
        "        return expert_ids, expert_weights"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ─── Expert Bank ──────────────────────────────────────────────\n",
        "\n",
        "class Expert(nn.Module):\n",
        "    \"\"\"Single FFN expert: W_up → act → W_down\"\"\"\n",
        "    def __init__(self, d_model: int, d_ff: int):\n",
        "        super().__init__()\n",
        "        self.up = nn.Linear(d_model, d_ff)\n",
        "        self.down = nn.Linear(d_ff, d_model)\n",
        "        self.act = nn.SiLU()\n",
        "    \n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        return self.down(self.act(self.up(x)))\n",
        "\n",
        "class ExpertBank(nn.Module):\n",
        "    \"\"\"Collection of n_experts FFN layers\"\"\"\n",
        "    def __init__(self, n_experts: int, d_model: int, d_ff: int):\n",
        "        super().__init__()\n",
        "        self.n_experts = n_experts\n",
        "        self.d_model = d_model\n",
        "        self.d_ff = d_ff\n",
        "        self.experts = nn.ModuleList([Expert(d_model, d_ff) for _ in range(n_experts)])\n",
        "    \n",
        "    def forward(self, x: torch.Tensor, expert_ids: torch.Tensor) -> Dict[int, torch.Tensor]:\n",
        "        \"\"\"\n",
        "        Sparse dispatch: only compute for active experts.\n",
        "        Returns dict of expert_id → output tensor.\n",
        "        \"\"\"\n",
        "        outputs = {}\n",
        "        for e in range(self.n_experts):\n",
        "            # Find which batch tokens route to expert e\n",
        "            mask = (expert_ids == e).any(dim=1)  # [batch]\n",
        "            if not mask.any():\n",
        "                continue\n",
        "            \n",
        "            # Get token indices for this expert\n",
        "            token_indices = mask.nonzero(as_tuple=True)[0]\n",
        "            expert_tokens = x[token_indices]  # [n_tokens, d_model]\n",
        "            \n",
        "            # Forward through expert\n",
        "            outputs[e] = self.experts[e](expert_tokens)\n",
        "        \n",
        "        return outputs\n",
        "\n",
        "class CombineStrategy(nn.Module):\n",
        "    \"\"\"Merge expert outputs back into single tensor\"\"\"\n",
        "    def __init__(self, k_active: int):\n",
        "        super().__init__()\n",
        "        self.k_active = k_active\n",
        "    \n",
        "    def forward(self, outputs: Dict[int, torch.Tensor], expert_ids: torch.Tensor, \n",
        "                expert_weights: torch.Tensor, batch_size: int, d_model: int) -> torch.Tensor:\n",
        "        # Uniform combine: simple average of active experts\n",
        "        result = torch.zeros(batch_size, d_model, device=device)\n",
        "        for b in range(batch_size):\n",
        "            count = 0\n",
        "            for k in range(self.k_active):\n",
        "                e = expert_ids[b, k].item()\n",
        "                if e in outputs:\n",
        "                    result[b] += outputs[e][count]\n",
        "                    count += 1\n",
        "            if count > 0:\n",
        "                result[b] /= count\n",
        "        return result"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ─── HGSEL Layer ──────────────────────────────────────────────\n",
        "\n",
        "class HGSELLayer(nn.Module):\n",
        "    \"\"\"\n",
        "    Hash-based Sparse Expert Layer\n",
        "    \n",
        "    Replaces standard MLP with sparse expert bank + deterministic routing.\n",
        "    \n",
        "    Args:\n",
        "        d_model: embedding dimension\n",
        "        d_ff: expert intermediate dimension\n",
        "        n_experts: total experts (default 64)\n",
        "        k_active: active experts per token (default 2)\n",
        "        n_hashes: routing hash functions (default 4)\n",
        "    \"\"\"\n",
        "    def __init__(self, d_model: int, d_ff: int, n_experts: int = 64, \n",
        "                 k_active: int = 2, n_hashes: int = 4, layer_id: int = 0):\n",
        "        super().__init__()\n",
        "        self.router = MultiHashRouter(n_experts, k_active, n_hashes, d_model, layer_id)\n",
        "        self.expert_bank = ExpertBank(n_experts, d_model, d_ff)\n",
        "        self.combine = CombineStrategy(k_active)\n",
        "        self.n_experts = n_experts\n",
        "        self.k_active = k_active\n",
        "        self.expert_load = torch.zeros(n_experts)\n",
        "        self.ema_decay = 0.99\n",
        "    \n",
        "    def set_salt(self, salt: float):\n",
        "        self.router.set_salt(salt)\n",
        "    \n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        # Route\n",
        "        expert_ids, expert_weights = self.router(x)\n",
        "        \n",
        "        # Sparse expert dispatch\n",
        "        expert_outputs = self.expert_bank(x, expert_ids)\n",
        "        \n",
        "        # Combine\n",
        "        batch_size = x.shape[0] if x.dim() == 2 else x.shape[1]\n",
        "        d_model = x.shape[-1]\n",
        "        if x.dim() == 3:\n",
        "            batch_size = x.shape[0] * x.shape[1]\n",
        "        \n",
        "        output = self.combine(expert_outputs, expert_ids, expert_weights, batch_size, d_model)\n",
        "        \n",
        "        # Update load EMA\n",
        "        self._update_load_ema(expert_ids)\n",
        "        \n",
        "        return output\n",
        "    \n",
        "    def _update_load_ema(self, expert_ids: torch.Tensor):\n",
        "        # Count activations per expert\n",
        "        counts = torch.bincount(expert_ids.flatten(), minlength=self.n_experts)\n",
        "        total = counts.sum().item()\n",
        "        if total == 0:\n",
        "            return\n",
        "        normalized = counts.float() / total\n",
        "        self.expert_load = self.ema_decay * self.expert_load + (1 - self.ema_decay) * normalized\n",
        "    \n",
        "    def routing_entropy(self) -> float:\n",
        "        probs = self.expert_load.cpu().numpy()\n",
        "        probs = probs[probs > 1e-8]\n",
        "        if len(probs) == 0:\n",
        "            return 0.5\n",
        "        entropy = -np.sum(probs * np.log(probs))\n",
        "        max_entropy = np.log(self.n_experts)\n",
        "        return entropy / max_entropy\n",
        "\n",
        "import numpy as np"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## ══════════════════════════════════════════════════════════════\n",
        "## Baseline Models\n",
        "## ══════════════════════════════════════════════════════════════\n",
        "\n",
        "For fair comparison, we need:\n",
        "1. **Dense Transformer** (naive FFN baseline)\n",
        "2. **RWKV-100M** (linear attention RNN)\n",
        "3. **Mamba-130M** (state space model)\n",
        "\n",
        "We implement a simple dense transformer as reference, then load pretrained RWKV/Mamba."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ─── Dense Transformer (FFN baseline) ────────────────────────\n",
        "\n",
        "class DenseFFN(nn.Module):\n",
        "    \"\"\"Standard dense FFN — our baseline\"\"\"\n",
        "    def __init__(self, d_model: int, d_ff: int):\n",
        "        super().__init__()\n",
        "        self.up = nn.Linear(d_model, d_ff)\n",
        "        self.down = nn.Linear(d_ff, d_model)\n",
        "        self.act = nn.SiLU()\n",
        "    \n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        return self.down(self.act(self.up(x)))\n",
        "\n",
        "class DenseTransformerBlock(nn.Module):\n",
        "    def __init__(self, d_model: int, n_heads: int, d_ff: int):\n",
        "        super().__init__()\n",
        "        self.attn = nn.MultiheadAttention(d_model, n_heads, batch_first=True)\n",
        "        self.ffn = DenseFFN(d_model, d_ff)\n",
        "        self.norm1 = nn.LayerNorm(d_model)\n",
        "        self.norm2 = nn.LayerNorm(d_model)\n",
        "    \n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        # Self-attention with residual\n",
        "        attn_out, _ = self.attn(x, x, x)\n",
        "        x = self.norm1(x + attn_out)\n",
        "        # FFN with residual\n",
        "        x = self.norm2(x + self.ffn(x))\n",
        "        return x\n",
        "\n",
        "class DenseTransformer(nn.Module):\n",
        "    \"\"\"Small dense transformer for comparison\"\"\"\n",
        "    def __init__(self, vocab_size: int, d_model: int, n_heads: int, n_layers: int, d_ff: int):\n",
        "        super().__init__()\n",
        "        self.embed = nn.Embedding(vocab_size, d_model)\n",
        "        self.layers = nn.ModuleList([DenseTransformerBlock(d_model, n_heads, d_ff) for _ in range(n_layers)])\n",
        "        self.lm_head = nn.Linear(d_model, vocab_size)\n",
        "    \n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        x = self.embed(x)\n",
        "        for layer in self.layers:\n",
        "            x = layer(x)\n",
        "        return self.lm_head(x)"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ─── RWKV Loader ──────────────────────────────────────────────\n",
        "\n",
        "# RWKV is available in the RWKV-LM package\n",
        "!pip install rwkv -q\n",
        "\n",
        "from transformers import AutoTokenizer\n",
        "\n",
        "def load_rwkv_100m():\n",
        "    \"\"\"Load RWKV-100M from HuggingFace\"\"\"\n",
        "    # RWKV-100M available via HuggingFace\n",
        "    # For now, we use a simple mock since actual RWKV loading requires special setup\n",
        "    print(\"RWKV loading requires special setup. Using mock for benchmark.\")\n",
        "    print(\"For full RWKV benchmark, see: https://huggingface.co/RWKV\")\n",
        "    return None  # Placeholder\n",
        "\n",
        "# Mock class for testing throughput\n",
        "class MockRWKV(nn.Module):\n",
        "    \"\"\"Mock RWKV for throughput testing — structure is similar but not pretrained\"\"\"\n",
        "    def __init__(self, vocab_size: int, d_model: int, n_layers: int):\n",
        "        super().__init__()\n",
        "        self.embed = nn.Embedding(vocab_size, d_model)\n",
        "        # Simplified RWKV-like structure\n",
        "        self.layers = nn.ModuleList([\n",
        "            nn.Linear(d_model, d_model * 4) for _ in range(n_layers)\n",
        "        ])\n",
        "        self.lm_head = nn.Linear(d_model, vocab_size)\n",
        "    \n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        x = self.embed(x)\n",
        "        for layer in self.layers:\n",
        "            x = x + torch.sigmoid(layer(x)) * torch.tanh(layer(x))  # Simple time mixing\n",
        "        return self.lm_head(x)\n",
        "\n",
        "def count_params(model: nn.Module) -> int:\n",
        "    return sum(p.numel() for p in model.parameters())"
      ],
      "execution_count": null,
      "outputs": []
    },
