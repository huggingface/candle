        "    \n",
        "    # Simple tokenization\n",
        "    import re\n",
        "    tokens = re.findall(r'\\b\\w+\\b|[.,!?;:]', training_text.lower())\n",
        "    print(f\"{len(tokens)} tokens\")\n",
        "    \n",
