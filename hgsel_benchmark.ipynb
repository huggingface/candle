    {
      "cell_type": "code",
      "source": [
        "# ─── Training Loop ───────────────────────────────────────────\n",
        "\n",
        "class TextDataset(Dataset):\n",
        "    \"\"\"Simple text dataset for training\"\"\"\n",
        "    def __init__(self, text: str, vocab_map: dict, seq_len: int = 64):\n",
        "        self.seq_len = seq_len\n",
        "        self.vocab_map = vocab_map\n",
        "        # Tokenize\n",
        "        import re\n",
        "        self.tokens = [vocab_map.get(t, 0) for t in re.findall(r'\\b\\w+\\b|[.,!?;:]', text.lower())]\n",
        "        # Filter unknown\n",
        "        self.tokens = [t for t in self.tokens if t > 0]\n",
        "        self.n_samples = len(self.tokens) // seq_len\n",
        "    \n",
        "    def __len__(self):\n",
        "        return max(0, self.n_samples - 1)\n",
        "    \n",
        "    def __getitem__(self, idx):\n",
        "        x = torch.tensor(self.tokens[idx:idx+self.seq_len], dtype=torch.long)\n",
        "        y = torch.tensor(self.tokens[idx+1:idx+self.seq_len+1], dtype=torch.long)\n",
        "        return x, y\n",
        "\n",
        "def train_model(model, train_loader, val_loader, epochs=3, lr=1e-3):\n",
        "    \"\"\"Train model and compute validation perplexity\"\"\"\n",
        "    model = model.to(device)\n",
        "    optimizer = torch.optim.AdamW(model.parameters(), lr=lr)\n",
        "    criterion = nn.CrossEntropyLoss()\n",
        "    \n",
        "    for epoch in range(epochs):\n",
        "        model.train()\n",
        "        total_loss = 0\n",
        "        for batch_idx, (x, y) in enumerate(train_loader):\n",
        "            x, y = x.to(device), y.to(device)\n",
        "            \n",
        "            optimizer.zero_grad()\n",
        "            logits = model(x)  # [batch, seq, vocab]\n",
        "            \n",
        "            # Shift for language modeling\n",
        "            shift_logits = logits[:, :-1, :].contiguous()\n",
        "            shift_labels = y[:, 1:].contiguous()\n",
        "            \n",
        "            loss = criterion(shift_logits.view(-1, logits.size(-1)), shift_labels.view(-1))\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "            \n",
        "            total_loss += loss.item()\n",
        "            if batch_idx % 10 == 0:\n",
        "                print(f\"  Epoch {epoch+1}, Batch {batch_idx}/{len(train_loader)}, Loss: {loss.item():.4f}\")\n",
        "        \n",
        "        avg_train_loss = total_loss / len(train_loader)\n",
        "        train_ppl = math.exp(avg_train_loss)\n",
        "        print(f\"  Epoch {epoch+1} train loss: {avg_train_loss:.4f}, perplexity: {train_ppl:.2f}\")\n",
        "    \n",
        "        # Validation\n",
        "        model.eval()\n",
        "        val_loss = 0\n",
        "        with torch.no_grad():\n",
        "            for x, y in val_loader:\n",
        "                x, y = x.to(device), y.to(device)\n",
        "                logits = model(x)\n",
        "                shift_logits = logits[:, :-1, :].contiguous()\n",
        "                shift_labels = y[:, 1:].contiguous()\n",
        "                loss = criterion(shift_logits.view(-1, logits.size(-1)), shift_labels.view(-1))\n",
        "                val_loss += loss.item()\n",
        "        \n",
        "        val_ppl = math.exp(val_loss / len(val_loader))\n",
        "        print(f\"  Epoch {epoch+1} val perplexity: {val_ppl:.2f}\")\n",
        "    \n",
        "    return val_ppl\n",
        "\n",
        "import math\n",
        "\n",
        "if training_text is not None:\n",
        "    print(f\"Training on {len(training_text)} chars...\")\n",
        "    \n",
        "    # Split train/val\n",
        "    split = int(len(training_text) * 0.9)\n",
        "    train_text = training_text[:split]\n",
        "    val_text = training_text[split:]\n",
        "    \n",
        "    train_ds = TextDataset(train_text, vocab_map)\n",
        "    val_ds = TextDataset(val_text, vocab_map)\n",
        "    \n",
        "    train_loader = DataLoader(train_ds, batch_size=16, shuffle=True)\n",
        "    val_loader = DataLoader(val_ds, batch_size=16)\n",
        "    \n",
        "    print(f\"Train samples: {len(train_ds)}, Val samples: {len(val_ds)}\")\n",
        "    \n",
        "    # Train HGSEL (quick 1 epoch for testing)\n",
        "    print(\"\\n--- Training HGSEL ---\")\n",
        "    hgsel_trained = HGSELLayer(256, 1024, n_experts=8, k_active=2, n_hashes=2)  # Smaller for quick test\n",
        "    train_model(hgsel_trained, train_loader, val_loader, epochs=1)\n",
        "else:\n",
        "    print(\"Skipping training — no data\")"
      ],
      "execution_count": null,
      "outputs": []
    },
