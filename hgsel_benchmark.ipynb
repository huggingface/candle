      "cell_type": "markdown",
      "source": [
        "## ══════════════════════════════════════════════════════════════\n",
        "## Phase 1: Throughput Benchmark\n",
        "## ══════════════════════════════════════════════════════════════\n",
        "\n",
        "Measure tokens/sec on fixed CPU/GPU hardware."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ─── Benchmark Setup ─────────────────────────────────────────\n",
        "\n",
        "VOCAB_SIZE = 50257  # GPT-2 vocab\n",
        "D_MODEL = 768\n",
        "N_HEADS = 12\n",
        "D_FF = 2048\n",
        "N_LAYERS = 12\n",
        "SEQ_LEN = 128\n",
        "BATCH_SIZE = 8\n",
        "\n",
        "# Create test input\n",
        "test_input = torch.randint(0, VOCAB_SIZE, (BATCH_SIZE, SEQ_LEN), device=device)\n",
        "\n",
        "# Generate dummy text for testing\n",
        "dummy_text = \"This is a test prompt for benchmarking HGSEL throughput. \" * 32\n",
        "\n",
        "def benchmark_throughput(model, test_input, n_runs=10, warmup=3):\n",
        "    \"\"\"Measure tokens/sec\"\"\"\n",
        "    model.eval()\n",
        "    \n",
        "    # Warmup\n",
        "    with torch.no_grad():\n",
        "        for _ in range(warmup):\n",
        "            _ = model(test_input)\n",
        "    \n",
        "    if device.type == 'cuda':\n",
        "        torch.cuda.synchronize()\n",
        "    \n",
        "    times = []\n",
        "    for _ in range(n_runs):\n",
        "        start = time.time()\n",
        "        with torch.no_grad():\n",
        "            _ = model(test_input)\n",
        "        if device.type == 'cuda':\n",
        "            torch.cuda.synchronize()\n",
        "        times.append(time.time() - start)\n",
        "    \n",
        "    avg_time = sum(times) / len(times)\n",
        "    total_tokens = BATCH_SIZE * SEQ_LEN\n",
        "    tokens_per_sec = total_tokens / avg_time\n",
        "    \n",
        "    return tokens_per_sec, avg_time\n",
        "\n",
        "def benchmark_memory(model, test_input):\n",
        "    \"\"\"Measure peak memory in MB\"\"\"\n",
        "    if device.type == 'cuda':\n",
        "        torch.cuda.reset_peak_memory_stats()\n",
        "        with torch.no_grad():\n",
        "            _ = model(test_input)\n",
        "        peak_mb = torch.cuda.max_memory_allocated() / (1024**2)\n",
        "        return peak_mb\n",
        "    return 0.0  # CPU doesn't have easy memory tracking"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ─── Build Models ─────────────────────────────────────────────\n",
        "\n",
        "print(\"Building models...\")\n",
        "\n",
        "# HGSEL (64 experts, 2 active)\n",
        "# ~100M params: d_model=768, d_ff=2048, n_experts=64, k=2\n",
