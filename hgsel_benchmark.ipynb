    {
      "cell_type": "code",
      "source": [
        "# ─── Load Training Data ──────────────────────────────────────\n",
        "\n",
        "# Option 1: Upload from local (run this cell, use Files panel to upload)\n",
        "# Option 2: Download from URL (if you have a hosted version)\n",
        "# Option 3: Use a public dataset as proxy\n",
